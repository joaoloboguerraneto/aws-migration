{{- if .Values.podDisruptionBudget.enabled -}}
apiVersion: policy/v1
kind: PodDisruptionBudget
metadata:
  name: {{ include "stopwatch.fullname" . }}
  labels:
    {{- include "stopwatch.labels" . | nindent 4 }}
spec:
  minAvailable: {{ .Values.podDisruptionBudget.minAvailable }}
  selector:
    matchLabels:
      {{- include "stopwatch.selectorLabels" . | nindent 6 }}
{{- end }}
