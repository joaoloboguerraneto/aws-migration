apiVersion: v1
kind: Service
metadata:
  name: {{ include "stopwatch.fullname" . }}
  labels:
    {{- include "stopwatch.labels" . | nindent 4 }}
spec:
  type: {{ .Values.service.type }}
  ports:
    - name: http
      port: {{ .Values.service.port }}
      targetPort: http
      protocol: TCP
  selector:
    {{- include "stopwatch.selectorLabels" . | nindent 4 }}
